# ══════════════════════════════════════════════════════════════════════════════
# NetworkMonitor Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Neo4j ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 24
NEO4J_PASSWORD=CHANGE_ME_use_openssl_rand

# ── Settings API ──────────────────────────────────────────────────────────────
# Master key for AES-256 encryption of stored API keys.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Post-quantum note: 256-bit Fernet key provides ~128 bits of PQ security.
# Upgrade path: replace with Kyber-1024 KEM when liboqs-python is stable.
SETTINGS_ENCRYPTION_KEY=CHANGE_ME_generate_with_fernet

# Internal service-to-service authentication token
# Generate with: openssl rand -hex 32
INTERNAL_API_TOKEN=CHANGE_ME_openssl_rand_hex_32

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Used when SASL_SSL is enabled (post-quantum TLS 1.3 hardening)
# KAFKA_SASL_USERNAME=netwatch
# KAFKA_SASL_PASSWORD=CHANGE_ME_kafka_password

# ── OTX AlienVault ───────────────────────────────────────────────────────────
# Free account at https://otx.alienvault.com — provides 19M+ daily indicators
OTX_API_KEY=

# ── MISP ─────────────────────────────────────────────────────────────────────
# Your self-hosted or community MISP instance
MISP_URL=
MISP_API_KEY=

# ── HaveIBeenPwned ───────────────────────────────────────────────────────────
# API key from https://haveibeenpwned.com/API/Key
# Required for email breach monitoring. Password checks use k-anonymity.
HIBP_API_KEY=

# ── Suricata Emerging Threats ─────────────────────────────────────────────────
# ET Open is free (no key). ET Pro adds ~6,000 premium signatures.
ET_PRO_API_KEY=

# ── Packet Launcher (lab only) ────────────────────────────────────────────────
ENABLE_PACKET_LAUNCHER=false
LAUNCH_TOKEN=CHANGE_ME_if_enabling

# ── Network ───────────────────────────────────────────────────────────────────
NETWORK_RANGE=192.168.1.0/24
HOME_LAT=38.9
HOME_LON=-77.0
INTERFACE=eth0

# ── DNS Monitor ──────────────────────────────────────────────────────────────
# ENABLE_EPHEMERAL_TRACER requires CAP_NET_RAW and written authorisation
# to perform active probing on the monitored network.
ENABLE_EPHEMERAL_TRACER=false

# ── SOAR Blocker ──────────────────────────────────────────────────────────────
SEVERITY_THRESHOLD=2
MIN_ALERTS_TO_BLOCK=3
ALERT_WINDOW_SECONDS=60
BLOCK_TTL_SECONDS=3600
# BLOCKED_COUNTRIES=KP,IR  (ISO codes, leave blank to disable)
BLOCKED_COUNTRIES=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
